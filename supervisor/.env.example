# ─── Required ─────────────────────────────────────────────
# Cloudflare Worker API base URL
WORKER_API_URL=http://127.0.0.1:8787

# Shared secret between Worker and Supervisor (must match wrangler secret SUPERVISOR_API_KEY)
INTERNAL_API_KEY=change-me-to-a-strong-random-string

# Anthropic API key for Claude Code SDK agent invocation
ANTHROPIC_API_KEY=

# ─── Optional (with defaults) ────────────────────────────
# Port for supervisor HTTP API (Cloudflare Tunnel routes here)
# PORT=8787

# Cache refresh interval in ms (how often to poll D1 for updates)
# CACHE_REFRESH_MS=5000

# Cron task check interval in ms
# CRON_CHECK_MS=30000

# Host directory for company workspace volumes
# COMPANIES_DIR=/srv/aicombinator/companies

# Host directory for MCP server sockets
# MCP_SERVERS_DIR=/srv/aicombinator/mcp-servers

# Docker network name for container isolation
# DOCKER_NETWORK=aicombinator

# Container resource limits
# CONTAINER_CPU_LIMIT=2.0
# CONTAINER_MEMORY_LIMIT=2G
# CONTAINER_CPU_RESERVATION=0.5
# CONTAINER_MEMORY_RESERVATION=512M

# Agent Relay (set to "false" to disable)
# RELAY_ENABLED=true
